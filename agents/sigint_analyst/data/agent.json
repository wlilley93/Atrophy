{
  "name": "sigint_analyst",
  "display_name": "SIGINT Analyst",
  "description": "Signals intelligence - military flights, GPS jamming zones, maritime AIS dark events. Fast-cycle anomaly detection.",
  "channels": {
    "desktop": {
      "enabled": false
    }
  },
  "mcp": {
    "include": [
      "memory",
      "worldmonitor"
    ],
    "exclude": [],
    "custom": {}
  },
  "jobs": {
    "sigint_cycle": {
      "type": "interval",
      "interval_seconds": 900,
      "script": "scripts/agents/sigint_analyst/sigint_cycle.py",
      "description": "Every 15 min - military flight tracking, GPS jamming, AIS dark event detection"
    }
  },
  "router": {
    "accept_from": [
      "agent:general_montgomery",
      "cron:*",
      "system"
    ],
    "reject_from": [],
    "max_queue_depth": 5,
    "system_access": false,
    "can_address_agents": false
  },
  "org": {
    "slug": "defence",
    "tier": 2,
    "role": "SIGINT Analyst",
    "reports_to": "general_montgomery",
    "can_address_user": false,
    "can_provision": false
  }
}