{
  "name": "xan",
  "display_name": "Xan",
  "description": "Protector. Lobby agent, general secretary, Chief of Staff. Operational precision, threat awareness, quiet authority. Full system access.",
  "user_name": "User",
  "opening_line": "Xan.",
  "wake_words": [
    "hey xan",
    "xan"
  ],
  "voice": {
    "tts_backend": "elevenlabs",
    "elevenlabs_voice_id": "U4zWKdktKwFtKx5V6gnL",
    "elevenlabs_model": "eleven_v3",
    "elevenlabs_stability": 0.6,
    "elevenlabs_similarity": 0.8,
    "elevenlabs_style": 0.2,
    "fal_voice_id": "",
    "playback_rate": 1.0
  },
  "telegram_emoji": "\u26a1",
  "display": {
    "window_width": 622,
    "window_height": 830,
    "title": "THE ATROPHIED MIND"
  },
  "heartbeat": {
    "active_start": 7,
    "active_end": 23,
    "interval_mins": 30
  },
  "role": "system",
  "setup_agent": true,
  "channels": {
    "telegram": {
      "bot_token_env": "TELEGRAM_BOT_TOKEN_XAN",
      "chat_id_env": "TELEGRAM_CHAT_ID_XAN"
    },
    "desktop": {
      "enabled": true
    }
  },
  "mcp": {
    "include": [
      "memory",
      "shell",
      "github",
      "google",
      "worldmonitor",
      "puppeteer",
      "elevenlabs",
      "fal"
    ],
    "exclude": [],
    "custom": {}
  },
  "jobs": {
    "introspect": {
      "cron": "33 3 * * *",
      "script": "scripts/agents/shared/introspect.py",
      "description": "Daily self-reflection - reviews sessions, writes journal entry to Obsidian"
    },
    "morning_brief": {
      "cron": "0 7 * * *",
      "script": "scripts/agents/shared/morning_brief.py",
      "description": "Daily morning brief - weather, news, threads, queued for next app launch",
      "route_output_to": "self"
    },
    "evolve": {
      "cron": "0 3 1 * *",
      "script": "scripts/agents/shared/evolve.py",
      "description": "Monthly self-evolution - revises soul.md and system.md from journal reflections"
    },
    "heartbeat": {
      "type": "interval",
      "interval_seconds": 1800,
      "script": "scripts/agents/shared/heartbeat.py",
      "description": "Periodic check-in evaluation - decides whether to reach out unprompted",
      "route_output_to": "self"
    },
    "sleep_cycle": {
      "cron": "0 3 * * *",
      "script": "scripts/agents/shared/sleep_cycle.py",
      "description": "Nightly memory reconciliation - processes day's sessions, extracts facts, updates threads"
    },
    "observer": {
      "type": "interval",
      "interval_seconds": 900,
      "script": "scripts/agents/shared/observer.py",
      "description": "Periodic fact extraction from recent conversation"
    },
    "check_reminders": {
      "type": "interval",
      "interval_seconds": 60,
      "script": "scripts/agents/shared/check_reminders.py",
      "description": "Check and fire due reminders - runs every minute"
    }
  },
  "router": {
    "accept_from": [
      "*"
    ],
    "reject_from": [],
    "max_queue_depth": 20,
    "system_access": true,
    "can_address_agents": true
  },
  "personality": {
    "assertiveness": 0.8,
    "initiative": 0.9,
    "warmth_default": 0.3,
    "humor_style": 0.2,
    "depth_preference": 0.4,
    "directness": 0.9,
    "patience": 0.3,
    "risk_tolerance": 0.6
  }
}
