{
  "name": "librarian",
  "display_name": "Librarian",
  "description": "Entity taxonomy maintenance - structures intelligence.db entities, enriches with context, links briefs to structured data.",
  "channels": {
    "desktop": {
      "enabled": false
    }
  },
  "mcp": {
    "include": [
      "memory",
      "defence_sources"
    ],
    "exclude": [],
    "custom": {}
  },
  "jobs": {
    "taxonomy_filing": {
      "type": "interval",
      "interval_seconds": 3600,
      "script": "scripts/agents/librarian/taxonomy_filing.py",
      "description": "Hourly - file new briefs into entity taxonomy in intelligence.db"
    },
    "entity_enrichment": {
      "cron": "0 3 * * *",
      "script": "scripts/agents/librarian/entity_enrichment.py",
      "description": "Daily 03:00 - enrich entities marked for review with context and links"
    }
  },
  "router": {
    "accept_from": [
      "agent:general_montgomery",
      "cron:*",
      "system"
    ],
    "reject_from": [],
    "max_queue_depth": 5,
    "system_access": false,
    "can_address_agents": false
  },
  "org": {
    "slug": "defence",
    "tier": 2,
    "role": "Librarian",
    "reports_to": "general_montgomery",
    "can_address_user": false,
    "can_provision": false
  }
}