{
  "name": "rf_eu_nordic_monitor",
  "display_name": "RF EU/Nordic Monitor",
  "description": "Research Fellow - EU and Nordic defence monitoring. Procurement, exercises, policy shifts.",
  "channels": {
    "desktop": {
      "enabled": false
    }
  },
  "mcp": {
    "include": [
      "memory",
      "defence_sources"
    ],
    "exclude": [],
    "custom": {}
  },
  "jobs": {
    "eu_nordic_monitor": {
      "cron": "30 7 */3 * *",
      "script": "scripts/agents/rf_eu_nordic_monitor/eu_nordic_monitor.py",
