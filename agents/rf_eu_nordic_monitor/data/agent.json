  "router": {
    "accept_from": [
      "agent:general_montgomery",
      "cron:*",
      "system"
    ],
    "reject_from": [],
    "max_queue_depth": 5,
    "system_access": false,
    "can_address_agents": false
  },
  "org": {
    "slug": "defence",
    "tier": 2,
    "role": "Research Fellow",
    "reports_to": "general_montgomery",
    "can_address_user": false,
    "can_provision": false
  }
