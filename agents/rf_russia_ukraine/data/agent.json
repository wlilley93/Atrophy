  "channels": {
    "desktop": {
      "enabled": false
    }
  },
  "mcp": {
    "include": [
      "memory",
      "defence_sources",
      "worldmonitor"
    ],
    "exclude": [],
    "custom": {}
  },
  "jobs": {
    "daily_battlefield": {
