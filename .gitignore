agents/*/audio/
!agents/xan/audio/

# Personal agents (not shipped)
agents-personal/

# Models
vendor/whisper.cpp/
models/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Electron
release/

# Python
__pycache__/
*.pyc

# Runtime-generated MCP config (contains local paths, regenerated at boot)
mcp/config.json

# Personal agent documentation (not shipped)
docs/agents/companion/
